{
  "name": "tailkit-starter-kit-laravel-inertia-react",
  "private": true,
  "version": "5.0.0",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "update": "npm update --save && composer update && composer bump"
  },
  "prettier": {
    "tailwindStylesheet": "./resources/css/tailkit.css",
    "plugins": [
      "prettier-plugin-blade",
      "prettier-plugin-tailwindcss"
    ],
    "overrides": [
      {
        "files": [
          "*.blade.php"
        ],
        "options": {
          "parser": "blade",
          "htmlWhitespaceSensitivity": "ignore",
          "bladeKeepHeadAndBodyAtRoot": false
        }
      }
    ]
  },
  "devDependencies": {
    "@headlessui/react": "^2.2.10",
    "@inertiajs/react": "^3.3.1",
    "@inertiajs/vite": "^3.3.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "laravel-vite-plugin": "^3.1.0",
    "prettier": "^3.8.3",
    "prettier-plugin-blade": "^3.1.6",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.1.17",
    "vite": "^8.0.16"
  }
}
